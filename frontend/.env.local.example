# ══════════════════════════════════════════════════════════════════════
#  ConnectBarcodes Frontend — Environment Variables Template
#  Copy to .env.local and fill in your values
# ══════════════════════════════════════════════════════════════════════

# ── Medusa Backend ────────────────────────────────────────────────────
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.connectbarcodes.com
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
MEDUSA_BACKEND_URL=https://api.connectbarcodes.com

# ── Stripe ────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ── Algolia ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=20C3UUXFBH
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=YOUR_SEARCH_ONLY_KEY
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=connect_barcodes_products

# ── Admin Auth ────────────────────────────────────────────────────────
ADMIN_PASSWORD=STRONG_ADMIN_PASSWORD
NEXTAUTH_SECRET=GENERATE_STRONG_SECRET
NEXTAUTH_URL=https://connectbarcodes.com

# ── Node ──────────────────────────────────────────────────────────────
NODE_ENV=production
