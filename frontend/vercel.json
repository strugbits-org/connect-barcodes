{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_MEDUSA_BACKEND_URL": "@medusa_backend_url",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "@stripe_publishable_key",
    "NEXT_PUBLIC_ALGOLIA_APP_ID": "@algolia_app_id",
    "NEXT_PUBLIC_ALGOLIA_SEARCH_KEY": "@algolia_search_key",
    "NEXT_PUBLIC_ALGOLIA_INDEX_NAME": "@algolia_index_name",
    "STRIPE_SECRET_KEY": "@stripe_secret_key",
    "ADMIN_PASSWORD": "@admin_password",
    "NEXTAUTH_SECRET": "@nextauth_secret"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "redirects": [
    { "source": "/admin/login", "destination": "/admin/login", "permanent": false }
  ]
}
